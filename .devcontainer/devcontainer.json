// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "AI Tour Repo",
	"image": "mcr.microsoft.com/devcontainers/python:3.13-trixie",
	"features": {
		"ghcr.io/devcontainers/features/python:1": {},
		"ghcr.io/devcontainers/features/azure-cli:1": {
			"extensions": "ml"
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/azure/azure-dev/azd:latest": {},
		"ghcr.io/devcontainers/features/copilot-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-ossdata.vscode-pgsql"
			]
		}
	},
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y postgresql-client && mkdir -p ~/.copilot && echo '{\"mcpServers\":{\"azure\":{\"type\":\"local\",\"command\":\"npx\",\"args\":[\"-y\",\"@azure/mcp@latest\",\"server\",\"start\"],\"tools\":[\"*\"]}}}' > ~/.copilot/mcp-config.json"
}